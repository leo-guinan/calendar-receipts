{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Calendar Receipt",
  "type": "object",
  "required": [
    "id",
    "type",
    "project",
    "created_at",
    "promise",
    "result",
    "status",
    "evidence"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "date": {
      "type": "string"
    },
    "period": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "closed_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "promise": {
      "type": "string"
    },
    "result": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "enum": [
        "open",
        "closed_hit",
        "closed_partial",
        "closed_miss",
        "blocked",
        "cancelled"
      ]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
